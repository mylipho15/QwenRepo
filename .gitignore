```gitignore
# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Dependencies
vendor/
node_modules/

# Build artifacts
dist/
build/
target/

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
coverage/
htmlcov/

# PHP specific
*.php~
*.php.bak

# Editor specific
.vscode/
.idea/
*.swp
*.swo

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```