# Examples where you might want to ignore certain files:
# Compiled/Binary files
*.pyc
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependency directories
node_modules/
venv/
.venv/
__pycache__/
.mypy_cache/
.pytest_cache/
target/
.gradle/

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# Environment files
.env
.env.local
*.env.*

# Build/dist directories
dist/
build/
out/
bin/
lib/
tmp/
temp/

# Database related (if not part of source)
*.db
*.sqlite
*.sqlite3

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# PHP specific
*.php~
php_errors.log
error_log
composer.lock

# Web specific
*.min.js
*.min.css
.sass-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*