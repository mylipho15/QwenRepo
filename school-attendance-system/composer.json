{
  "name": "school-attendance-system",
  "version": "1.0.0",
  "description": "Sistem Absensi Siswa Berbasis Web dengan Multi-Theme Support",
  "type": "project",
  "keywords": [
    "attendance",
    "school",
    "php",
    "mysql",
    "web-application"
  ],
  "authors": [
    {
      "name": "Developer",
      "email": "developer@school.local"
    }
  ],
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-mysqli": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "SchoolAttendance\\Libs\\": "libs/"
    },
    "files": [
      "config/database.php"
    ]
  },
  "scripts": {
    "setup": "php scripts/setup.php",
    "install-db": "php scripts/install-db.php install",
    "reset-db": "php scripts/install-db.php reset",
    "test": "phpunit"
  },
  "config": {
    "platform": {
      "php": "7.4"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
