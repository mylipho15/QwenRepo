{
    "name": "school-attendance-system",
    "version": "1.0.0",
    "description": "Sistem Absensi Siswa Berbasis Web untuk SMK",
    "type": "project",
    "keywords": [
        "attendance",
        "school",
        "php",
        "mysql",
        "web"
    ],
    "authors": [
        {
            "name": "Developer",
            "email": "developer@example.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-mysqli": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "install": [
            "php -r \"echo 'Checking PHP version...\\n';\"",
            "php -r \"if (version_compare(PHP_VERSION, '7.4.0', '<')) { throw new Exception('PHP 7.4 or higher is required'); }\""
        ],
        "setup": [
            "php scripts/setup.php"
        ],
        "test": "phpunit"
    },
    "config": {
        "platform": {
            "php": "7.4"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
